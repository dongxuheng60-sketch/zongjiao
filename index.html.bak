<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>华夏建筑数据库</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      background: #0a0a0a;
      color: #e8d5b7;
      min-height: 100vh;
    }

    /* Hero */
    .hero {
      position: relative;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 30% 60%, rgba(139,90,43,.15) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 30%, rgba(180,100,40,.1) 0%, transparent 50%),
        linear-gradient(180deg, #0a0a0a 0%, #1a0f08 50%, #0a0a0a 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 800px;
      padding: 2rem;
    }
    .hero-subtitle {
      font-size: .85rem;
      letter-spacing: 8px;
      color: #b87333;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 1s ease .3s forwards;
    }
    .hero-title {
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 700;
      color: #f5e6c8;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 1s ease .6s forwards;
    }
    .hero-title span { color: #b87333; }
    .hero-desc {
      font-size: 1.1rem;
      color: #8a7060;
      line-height: 1.8;
      max-width: 600px;
      margin: 0 auto 2.5rem;
      opacity: 0;
      animation: fadeUp 1s ease .9s forwards;
    }
    .hero-scroll {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      opacity: 0;
      animation: fadeUp 1s ease 1.2s forwards;
    }
    .scroll-indicator {
      width: 1px;
      height: 60px;
      background: linear-gradient(180deg, #b87333, transparent);
      margin: 0 auto;
      animation: scrollPulse 2s ease infinite;
    }

    /* Stats */
    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 4rem;
      padding: 3rem 2rem;
      background: #111;
      border-top: 1px solid rgba(184,115,51,.2);
      border-bottom: 1px solid rgba(184,115,51,.2);
    }
    .stat-item { text-align: center; }
    .stat-number {
      font-size: 2.5rem;
      font-weight: 700;
      color: #b87333;
      font-family: Georgia, serif;
    }
    .stat-label {
      font-size: .8rem;
      color: #6a5a4a;
      margin-top: .3rem;
      letter-spacing: 2px;
    }

    /* Filter */
    .filter-section {
      padding: 3rem 2rem 1rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    .filter-title {
      font-size: .75rem;
      letter-spacing: 4px;
      color: #6a5a4a;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .filter-tabs { display: flex; gap: .5rem; flex-wrap: wrap; }
    .filter-tab {
      padding: .5rem 1.2rem;
      border: 1px solid rgba(184,115,51,.3);
      border-radius: 2rem;
      background: transparent;
      color: #8a7060;
      font-size: .85rem;
      cursor: pointer;
      transition: all .3s;
      font-family: inherit;
    }
    .filter-tab:hover, .filter-tab.active {
      background: rgba(184,115,51,.15);
      border-color: #b87333;
      color: #b87333;
    }

    .result-count {
      padding: 0 2rem 1rem;
      font-size: .8rem;
      color: #6a5a4a;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* Grid */
    .grid-section {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1rem 2rem 4rem;
    }
    .buildings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5rem;
    }

    /* Card */
    .card {
      background: #111;
      border: 1px solid rgba(184,115,51,.15);
      border-radius: 4px;
      overflow: hidden;
      cursor: pointer;
      transition: all .4s ease;
      opacity: 0;
      transform: translateY(20px);
    }
    .card.visible { opacity: 1; transform: translateY(0); }
    .card:hover {
      border-color: rgba(184,115,51,.5);
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(0,0,0,.5);
    }
    .card:hover .card-img { transform: scale(1.05); }
    .card-img-wrap {
      height: 200px;
      overflow: hidden;
      position: relative;
    }
    .card-img {
      width: 100%;
      height: 100%;
      transition: transform .6s ease;
    }
    .card-img-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #1a1209, #2a1a0a);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-img-placeholder .char {
      font-size: 3rem;
      color: rgba(184,115,51,.3);
      font-family: Georgia, serif;
    }
    .card-badge {
      position: absolute;
      top: 1rem;
      left: 1rem;
      padding: .25rem .8rem;
      background: rgba(10,10,10,.8);
      border: 1px solid rgba(184,115,51,.4);
      color: #b87333;
      font-size: .7rem;
      letter-spacing: 2px;
      backdrop-filter: blur(4px);
    }
    .card-body { padding: 1.5rem; }
    .card-meta {
      display: flex;
      gap: 1rem;
      margin-bottom: .8rem;
      font-size: .75rem;
      color: #6a5a4a;
    }
    .card-meta span { display: flex; align-items: center; gap: .3rem; }
    .card-title {
      font-size: 1.3rem;
      font-weight: 600;
      color: #f5e6c8;
      margin-bottom: .8rem;
      line-height: 1.3;
    }
    .card-desc {
      font-size: .85rem;
      color: #6a5a4a;
      line-height: 1.7;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-footer {
      display: flex;
      gap: .4rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .card-tag {
      padding: .2rem .6rem;
      background: rgba(184,115,51,.08);
      color: #7a5a3a;
      font-size: .7rem;
      border-radius: 2px;
    }

    /* Modal */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.92);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: #111;
      border: 1px solid rgba(184,115,51,.3);
      border-radius: 4px;
      max-width: 800px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }
    .modal-close {
      position: sticky;
      top: 1rem;
      float: right;
      margin: 1rem 1rem -3rem 0;
      width: 36px;
      height: 36px;
      border: 1px solid rgba(184,115,51,.3);
      background: #111;
      color: #b87333;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .3s;
      z-index: 10;
    }
    .modal-close:hover { background: rgba(184,115,51,.2); }
    .modal-header {
      height: 250px;
      background: linear-gradient(135deg, #1a1209, #2a1a0a);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .modal-header .char {
      font-size: 5rem;
      color: rgba(184,115,51,.2);
      font-family: Georgia, serif;
    }
    .modal-badge {
      position: absolute;
      top: 1.5rem;
      left: 1.5rem;
      padding: .3rem 1rem;
      background: rgba(184,115,51,.2);
      border: 1px solid rgba(184,115,51,.5);
      color: #b87333;
      font-size: .75rem;
      letter-spacing: 3px;
    }
    .modal-body { padding: 2.5rem; }
    .modal-title {
      font-size: 2rem;
      font-weight: 700;
      color: #f5e6c8;
      margin-bottom: 1rem;
    }
    .modal-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(184,115,51,.1);
    }
    .modal-meta-item { font-size: .8rem; color: #8a7060; }
    .modal-meta-item strong { color: #b87333; display: block; margin-bottom: .2rem; }
    .modal-features { margin-bottom: 2rem; }
    .modal-features h3 {
      font-size: .8rem;
      letter-spacing: 3px;
      color: #b87333;
      margin-bottom: 1rem;
      text-transform: uppercase;
    }
    .modal-features ul {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .5rem;
    }
    .modal-features li {
      font-size: .85rem;
      color: #8a7060;
      padding: .5rem 0;
      border-bottom: 1px solid rgba(184,115,51,.05);
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .modal-features li::before {
      content: "\25C6";
      color: #b87333;
      font-size: .5rem;
    }
    .modal-content h3 {
      font-size: .8rem;
      letter-spacing: 3px;
      color: #b87333;
      margin-bottom: 1rem;
      text-transform: uppercase;
    }
    .modal-content p {
      font-size: .9rem;
      color: #7a6a5a;
      line-height: 2;
    }

    /* Animations */
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
    @keyframes scrollPulse {
      0%, 100% { opacity: .3; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.2); }
    }

    /* Responsive */
    @media (max-width: 768px) {
      .stats-bar { gap: 2rem; flex-wrap: wrap; }
      .modal-features ul { grid-template-columns: 1fr; }
      .buildings-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <p class="hero-subtitle">Ancient Chinese Architecture</p>
    <h1 class="hero-title">华夏<span>建筑</span>数据库</h1>
    <p class="hero-desc">
      从北魏砖塔到清代园林，收录中国历代代表性古建筑，<br>
      涵盖塔寺、楼阁、石窟、园林、桥梁等类型
    </p>
    <div class="hero-scroll">
      <div class="scroll-indicator"></div>
    </div>
  </div>
</section>

<div class="stats-bar">
  <div class="stat-item">
    <div class="stat-number" id="total-count">-</div>
    <div class="stat-label">收录建筑</div>
  </div>
  <div class="stat-item">
    <div class="stat-number" id="type-count">-</div>
    <div class="stat-label">建筑类型</div>
  </div>
  <div class="stat-item">
    <div class="stat-number" id="era-count">-</div>
    <div class="stat-label">跨越朝代</div>
  </div>
</div>

<div class="filter-section">
  <div class="filter-title">分类筛选</div>
  <div class="filter-tabs" id="filter-tabs">
    <button class="filter-tab active" data-filter="全部">全部</button>
  </div>
</div>

<div class="result-count" id="result-count"></div>

<div class="grid-section">
  <div class="buildings-grid" id="buildings-grid"></div>
</div>

<div class="modal-overlay" id="modal">
  <div class="modal" id="modal-content"></div>
</div>

<script>
(async function() {
  const resp = await fetch('ancient_buildings.json');
  const buildings = await resp.json();

  const categories = [...new Set(buildings.map(b => b.category))];
  const dynasties = [...new Set(buildings.map(b => b.dynasty.split(/[、（]/)[0]))];

  document.getElementById('total-count').textContent = buildings.length;
  document.getElementById('type-count').textContent = categories.length;
  document.getElementById('era-count').textContent = dynasties.length;

  const filterTabs = document.getElementById('filter-tabs');
  categories.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'filter-tab';
    btn.dataset.filter = cat;
    btn.textContent = cat;
    filterTabs.appendChild(btn);
  });

  function render(filter) {
    const grid = document.getElementById('buildings-grid');
    const filtered = filter === '全部' ? buildings : buildings.filter(b => b.category === filter);
    document.getElementById('result-count').textContent = '共 ' + filtered.length + ' 项';
    grid.innerHTML = '';
    filtered.forEach((b, i) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.style.transitionDelay = (i * 60) + 'ms';
      card.innerHTML =
        '<div class="card-img-wrap">' +
          '<div class="card-img-placeholder"><span class="char">' + b.title[0] + '</span></div>' +
          '<div class="card-badge">' + b.category + '</div>' +
        '</div>' +
        '<div class="card-body">' +
          '<div class="card-meta">' +
            '<span> ' + b.dynasty + ' ' + (b.year || '') + '</span>' +
            (b.location ? '<span> ' + b.location + '</span>' : '') +
          '</div>' +
          '<h3 class="card-title">' + b.title + '</h3>' +
          '<p class="card-desc">' + b.description + '</p>' +
          '<div class="card-footer">' +
            b.tags.slice(0, 4).map(t => '<span class="card-tag">' + t + '</span>').join('') +
          '</div>' +
        '</div>';
      card.addEventListener('click', () => openModal(b));
      grid.appendChild(card);
    });
    requestAnimationFrame(() => {
      document.querySelectorAll('.card').forEach((c, idx) => {
        setTimeout(() => c.classList.add('visible'), idx * 60);
      });
    });
  }

  function openModal(b) {
    const modal = document.getElementById('modal');
    let metaHtml = '';
    if (b.dynasty) metaHtml += '<div class="modal-meta-item"><strong>建造年代</strong>' + b.dynasty + ' ' + (b.year || '') + '</div>';
    if (b.location) metaHtml += '<div class="modal-meta-item"><strong>地理位置</strong>' + b.location + '</div>';
    if (b.height) metaHtml += '<div class="modal-meta-item"><strong>建筑高度</strong>' + b.height + '</div>';
    if (b.floors) metaHtml += '<div class="modal-meta-item"><strong>层数</strong>' + b.floors + '</div>';
    if (b.shape) metaHtml += '<div class="modal-meta-item"><strong>形制</strong>' + b.shape + '</div>';

    let featuresHtml = '';
    if (b.features && b.features.length > 0) {
      featuresHtml =
        '<div class="modal-features">' +
          '<h3>建筑特色</h3>' +
          '<ul>' + b.features.map(f => '<li>' + f + '</li>').join('') + '</ul>' +
        '</div>';
    }

    document.getElementById('modal-content').innerHTML =
      '<button class="modal-close" id="modal-close-btn"> </button>' +
      '<div class="modal-header">' +
        '<span class="char">' + b.title[0] + '</span>' +
        '<div class="modal-badge">' + b.category + '</div>' +
      '</div>' +
      '<div class="modal-body">' +
        '<h2 class="modal-title">' + b.title + '</h2>' +
        '<div class="modal-meta">' + metaHtml + '</div>' +
        featuresHtml +
        '<div class="modal-content">' +
          '<h3>详细介绍</h3>' +
          '<p>' + b.content + '</p>' +
        '</div>' +
      '</div>';
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    document.getElementById('modal-close-btn').addEventListener('click', closeModal);
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  filterTabs.addEventListener('click', e => {
    if (e.target.classList.contains('filter-tab')) {
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      e.target.classList.add('active');
      render(e.target.dataset.filter);
    }
  });

  render('全部');
})();
</script>
</body>
</html>
